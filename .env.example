# ============================================================================
# .env.example — Variables de entorno de formulario-livskin
# ============================================================================
#
# COMO USARLO:
#   1. Copia este archivo a `.env` (sin el .example):
#        cp .env.example .env
#   2. Rellena los valores reales en `.env`.
#   3. NUNCA commitees `.env` a git (está en .gitignore).
#
# DONDE GUARDAR LOS VALORES REALES (los reales, no este template):
#   - Localmente: en `.env` (gitignored).
#   - En producción (Render): en Render Dashboard → Service → Environment.
#   - Como backup maestro: en un gestor de contraseñas (Bitwarden, 1Password,
#     Proton Pass) bajo la entrada "Livskin - Variables de Entorno".
#     Esto es CRÍTICO para el día que cambies de PC: sin estas vars no se
#     puede levantar la app.
#
# ============================================================================

# --- Google Service Account (acceso a la Sheet de Livskin) ---
# Contenido completo del JSON de la service account, en una sola línea.
# Para generarlo:
#   1. Google Cloud Console → IAM → Service Accounts → livskin-formulario
#   2. Keys → Add Key → JSON → descargar
#   3. Pegar el contenido del JSON aquí (sin saltos de línea, en una línea)
# Si no se define, app.py intenta leer livskin-formulario-XXXX.json del directorio
# (modo desarrollo local).
GOOGLE_CREDENTIALS=

# --- Flask secret key (firma de sesiones y flash messages) ---
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# DEBE ser distinto en local y en producción. NUNCA usar el mismo valor.
# Si no se define, app.py genera una aleatoria efímera (sesiones se invalidan
# al reiniciar) — aceptable solo para dev.
FLASK_SECRET_KEY=

# --- Sheet ID de Google (la fuente de verdad de los datos) ---
# Lo encuentras en la URL de la Sheet:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
# Hoy está hardcoded en app.py:12. En el futuro debería leerse de aquí.
LIVSKIN_SHEET_ID=1o4Vh4RN_Qfpaz8g08MReqgE3mFX0EGVSI5A69OsHB5g
